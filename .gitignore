# .gitignore for Visual Studio (including VS 2022/2024/2026) and .NET projects
# Ignore Visual Studio temporary files, build results, and user-specific files

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.vssscc
*.vspscc

# Build results
[Bb]in/
[Oo]bj/
artifacts/
build/
publish/

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/packages/
project.lock.json
project.fragment.lock.json
project.assets.json

# Dotnet local tool/state
.dotnet/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Visual Studio Code
.vscode/

# Logs and databases
*.log
*.sql
*.sqlite
*.db
*.db3
*.mdf
*.ldf

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Others
*.vsix
*.vsixmanifest
*.nupkg
*.cache

# Node
node_modules/

# Ignore publish output folders commonly used by CI or local publish
publish_output/
/wwwroot/

# Ignore user secrets (if used)
secrets.json

# End of file
